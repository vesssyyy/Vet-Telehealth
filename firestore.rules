rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** PayMongo payment intent ownership — written only by Cloud Functions (Admin SDK). */
    match /paymongo_intents/{intentId} {
      allow read, write: if false;
    }

    /** Vet user doc must exist with role vet (avoids rule errors on missing profiles). */
    function isVet() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vet'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'veterinarian'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Veterinarian'
        );
    }

    /** WebRTC signaling lives under appointments; gate by parent appointment owner/vet. */
    function isAppointmentParticipantById(appointmentId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/appointments/$(appointmentId))
        && (get(/databases/$(database)/documents/appointments/$(appointmentId)).data.ownerId == request.auth.uid
            || get(/databases/$(database)/documents/appointments/$(appointmentId)).data.vetId == request.auth.uid);
    }

    /** Conversation access: supports owner/vet fields and participants[]. */
    function isConvMemberFromData(d) {
      return request.auth != null
        && (
          request.auth.uid == d.ownerId
          || request.auth.uid == d.vetId
          || (d.participants is list && request.auth.uid in d.participants)
        );
    }

    function conversationData(convId) {
      return get(/databases/$(database)/documents/conversations/$(convId)).data;
    }

    function isConvMember(convId) {
      return isConvMemberFromData(conversationData(convId));
    }

    match /appointments/{appointmentId} {
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || resource.data.vetId == request.auth.uid);
      allow update: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || resource.data.vetId == request.auth.uid);
      allow delete: if false;
    }

    match /appointments/{appointmentId}/videoCall/room {
      allow read, write: if isAppointmentParticipantById(appointmentId);
    }

    match /appointments/{appointmentId}/signaling/{msgId} {
      allow read: if isAppointmentParticipantById(appointmentId);
      allow create: if isAppointmentParticipantById(appointmentId)
        && request.resource.data.from == request.auth.uid;
      allow update: if false;
      allow delete: if isAppointmentParticipantById(appointmentId);
    }

    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId
        || resource.data.role == 'vet'
        || resource.data.role == 'veterinarian'
        || resource.data.role == 'Veterinarian'
        || (isVet() && resource.data.role == 'petOwner')
      );
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if false;
    }

    match /users/{userId}/schedules/{scheduleId} {
      allow read: if request.auth != null
        && (
          get(/databases/$(database)/documents/users/$(userId)).data.role == 'vet'
          || get(/databases/$(database)/documents/users/$(userId)).data.role == 'veterinarian'
          || get(/databases/$(database)/documents/users/$(userId)).data.role == 'Veterinarian'
        );
      allow create: if request.auth.uid == userId;
      allow update: if request.auth != null
        && (request.auth.uid == userId
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'petOwner');
      allow delete: if request.auth.uid == userId;
    }

    match /users/{userId}/vetSettings/{docId} {
      allow read: if request.auth != null
        && (
          get(/databases/$(database)/documents/users/$(userId)).data.role == 'vet'
          || get(/databases/$(database)/documents/users/$(userId)).data.role == 'veterinarian'
          || get(/databases/$(database)/documents/users/$(userId)).data.role == 'Veterinarian'
        );
      allow write: if request.auth.uid == userId;
    }

    match /users/{userId}/pets/{petId} {
      allow read, create, update: if request.auth.uid == userId
        || (isVet() && get(/databases/$(database)/documents/users/$(userId)).data.role == 'petOwner');
      allow delete: if request.auth.uid == userId
        || (isVet() && get(/databases/$(database)/documents/users/$(userId)).data.role == 'petOwner');
    }

    match /users/{userId}/template/{templateId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /conversations/{convId} {
      // Keep messaging permissive (as requested) to avoid creation/list failures.
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }

    match /conversations/{convId}/messages/{msgId} {
      // Keep messaging permissive (as requested) to avoid send/read failures.
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
  }
}
