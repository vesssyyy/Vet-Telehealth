# Copy to .env for local Firebase emulator / testing (never commit .env).
# For production, set GMAIL_USER and GMAIL_APP_PASSWORD in Firebase Console
# → Functions → your function → Configuration → Secrets / environment.

GMAIL_USER=
GMAIL_APP_PASSWORD=

# PayMongo test secret (sk_test_…) — Dashboard → Developers (test mode).
# Also set as a function parameter for deploy: firebase deploy will prompt, or use
# Firebase Console → Functions → payMongo* → Environment configuration.
PAYMONGO_SECRET_KEY=
